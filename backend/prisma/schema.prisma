generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  admin
  content_manager
}

enum ContentNodeType {
  concept
  fact
  highlight
  micro_note
  pyq
}

enum TestType {
  topic_wise
  subtopic_wise
  mixed
  pyq
  weak_area
  custom
}

enum TestStatus {
  active
  submitted
}

enum MainsQuestionType {
  gs
  essay
  ethics
  optional
}

enum MainsQuestionSource {
  pyq
  coaching
  ai_generated
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  role         UserRole     @default(student)
  sessions     Session[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  topics      Topic[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Topic {
  id               String        @id @default(uuid())
  subjectId        String
  parentTopicId    String?
  name             String
  slug             String
  description      String?
  materializedPath String
  subject          Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parentTopic      Topic?        @relation("TopicHierarchy", fields: [parentTopicId], references: [id], onDelete: Cascade)
  childTopics      Topic[]       @relation("TopicHierarchy")
  contentNodes     ContentNode[]
  mcqQuestions     McqQuestion[]
  mainsQuestions   MainsQuestion[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@index([parentTopicId])
  @@index([materializedPath])
}

model MainsQuestion {
  id                String              @id @default(uuid())
  topicId           String
  type              MainsQuestionType
  source            MainsQuestionSource
  marks             Int                 @default(10)
  questionText      String
  modelAnswer       String?
  suggestedWordLimit Int                @default(250)
  year              Int?
  topic             Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([topicId])
  @@index([type])
  @@index([source])
  @@index([marks])
}

model ContentNode {
  id        String          @id @default(uuid())
  topicId   String
  type      ContentNodeType
  title     String?
  body      String
  embedding Float[]         @default([])
  topic     Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([topicId])
}

model McqQuestion {
  id           String         @id @default(uuid())
  topicId      String
  questionText String
  optionA      String
  optionB      String
  optionC      String
  optionD      String
  correctOption String
  explanation  String?
  difficulty   Int            @default(2)
  isPyq        Boolean        @default(false)
  pyqYear      Int?
  topic        Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  testQuestions TestQuestion[]
  responses    TestResponse[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([topicId])
  @@index([isPyq])
}

model Test {
  id               String         @id @default(uuid())
  userId           String
  type             TestType
  status           TestStatus     @default(active)
  totalQuestions   Int
  timeLimitMinutes Int
  score            Float?
  negativeMarks    Float          @default(0)
  correctCount     Int            @default(0)
  incorrectCount   Int            @default(0)
  skippedCount     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  submittedAt      DateTime?
  testQuestions    TestQuestion[]
  responses        TestResponse[]

  @@index([userId, createdAt])
}

model TestQuestion {
  id         String      @id @default(uuid())
  testId     String
  questionId String
  sequence   Int
  test       Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  question   McqQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([testId, questionId])
  @@unique([testId, sequence])
  @@index([questionId])
}

model TestResponse {
  id              String      @id @default(uuid())
  testId          String
  questionId      String
  selectedOption  String?
  isCorrect       Boolean
  timeTakenSeconds Int        @default(0)
  isFlagged       Boolean     @default(false)
  test            Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  question        McqQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())

  @@unique([testId, questionId])
  @@index([testId])
  @@index([questionId])
}
